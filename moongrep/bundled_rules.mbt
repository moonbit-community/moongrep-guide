fn async_fs_tmpdir_weak_randomness(
  file : String,
  ast : Json,
  hits : Array[MatchHit],
) -> Bool {
  match ast {
    // rule: async/fs-tmpdir-weak-randomness pattern 0
    {
      "kind": "Expr::Apply",
      "loc": loc,
      "children": {
        "args": { "kind": "Expr::Apply::ArgumentList", "children": [], .. },
        "attr": { "kind": "ApplyAttr::NoAttr", "children": { .. }, .. },
        "func": {
