///|
priv struct NameOnlyBinding {
  meta_name : String
  occurrence : Int
  bind_name : String
}

///|
fn emit_pattern_source(
  node : Json,
  ctx : PatternEmitContext,
  root? : Bool = false,
) -> String raise {
  match recognize_metavar(node, ctx) {
    Some(binding_name) => binding_name
    None =>
      match emit_ast_node_source(node, ctx, root~) {
        Some(source) => source
        None =>
          match node {
            Object(map) => {
              let keys : Array[String] = []
              for entry in map.iter() {
                keys.push(entry.0)
              }
              keys.sort()
              let fields : Array[String] = []
              for key in keys {
                let value = map.get(key).unwrap()
                let field_source = emit_pattern_source(value, ctx)
                fields.push("\{emit_string_literal(key)}: \{field_source}")
              }
              if fields.is_empty() {
                "{ .. }"
              } else {
                let joined_fields = fields.join(", ")
                "{ \{joined_fields}, .. }"
              }
            }
            Array(items) =>
              if items.is_empty() {
                "[]"
              } else {
                let item_sources : Array[String] = []
                for item in items {
                  item_sources.push(emit_pattern_source(item, ctx))
                }
                let joined_items = item_sources.join(", ")
                "[\{joined_items}]"
              }
            String(value) => emit_string_literal(value)
            Number(_, ..) | True | False => node.stringify()
            Null => "Null"
          }
      }
  }
}

///|
fn emit_ast_node_source(
  node : Json,
  ctx : PatternEmitContext,
  root? : Bool = false,
) -> String? raise {
  match node {
    Object(map) =>
      if map.length() == 3 {
        match (map.get("kind"), map.get("loc"), map.get("children")) {
          (Some(kind), Some(_), Some(children)) => {
            let kind_source = emit_pattern_source(kind, ctx)
            let children_source = emit_pattern_source(children, ctx)
            if root {
              Some(
                "{ \"kind\": \{kind_source}, \"loc\": loc, \"children\": \{children_source}, .. }",
              )
            } else {
              Some(
                "{ \"kind\": \{kind_source}, \"children\": \{children_source}, .. }",
              )
            }
          }
          _ => None
        }
      } else {
        None
      }
    _ => None
  }
}

///|
fn record_binding(ctx : PatternEmitContext, meta_name : String) -> String {
  for index in 0..<ctx.bindings.length() {
    if ctx.bindings[index].meta_name == meta_name {
      let bind_names = ctx.bindings[index].bind_names
      let bind_name = emit_binding_name(meta_name, bind_names.length() + 1)
      bind_names.push(bind_name)
      return bind_name
    }
  }
  let bind_name = emit_binding_name(meta_name, 1)
  ctx.bindings.push({ meta_name, bind_names: [bind_name] })
  bind_name
}

///|
fn emit_binding_name(meta_name : String, occurrence : Int) -> String {
  if occurrence == 1 {
    meta_name
  } else {
    "\{sanitize_identifier(meta_name)}_\{occurrence}"
  }
}

///|
fn find_binding_record(
  ctx : PatternEmitContext,
  meta_name : String,
) -> BindingRecord? {
  for binding in ctx.bindings {
    if binding.meta_name == meta_name {
      return Some(binding)
    }
  }
  None
}

///|
fn sanitize_identifier(name : String) -> String {
  let builder = StringBuilder::new(size_hint=name.length() + 5)
  builder.write_string("meta_")
  for index in 0..<name.length() {
    let ch = name.code_unit_at(index).unsafe_to_char()
    if ch == '_' ||
      ch.is_ascii_digit() ||
      ch is ('a'..='z') ||
      ch is ('A'..='Z') {
      builder.write_char(ch)
    } else {
      builder.write_char('_')
    }
  }
  builder.to_string()
}

///|
fn emit_generated_local_name(
  stem : String,
  meta_name : String,
  occurrence : Int,
) -> String {
  "__moongrep_\{stem}_\{sanitize_identifier(meta_name)}_\{occurrence}"
}

///|
fn emit_name_only_option_name(meta_name : String, occurrence : Int) -> String {
  emit_generated_local_name("name_opt", meta_name, occurrence)
}

///|
fn emit_name_only_value_name(meta_name : String, occurrence : Int) -> String {
  emit_generated_local_name("name", meta_name, occurrence)
}

///|
fn emit_guard_function_name() -> String {
  "__moongrep_guard"
}

///|
fn emit_pattern_metavars(pattern : RulePatternSpec) -> Array[String] {
  let metavars : Array[String] = []
  for meta_name in pattern.structural_metavars {
    metavars.push(meta_name)
  }
  for meta_name in pattern.nameonly_metavars {
    metavars.push(meta_name)
  }
  metavars
}

///|
fn emit_string_literal(value : String) -> String {
  Json::string(value).stringify()
}

///|
fn emit_bundle_source(rules : Array[RuleSpec]) -> String raise {
  let builder = StringBuilder::new()
  builder.write_string("// Generated by `moon run bundler`. DO NOT EDIT.\n")
  builder.write_string("\n")
  builder.write_string(emit_matcher_source(rules))
  builder.to_string()
}

///|
fn emit_matcher_source(rules : Array[RuleSpec]) -> String raise {
  let builder = StringBuilder::new()
  let rule_function_names = emit_rule_matcher_function_names(rules)
  for rule_index in 0..<rules.length() {
    builder.write_string(
      emit_rule_matcher_source(
        rule_function_names[rule_index],
        rules[rule_index],
      ),
    )
    builder.write_string("\n")
  }
  builder.write_string(emit_rules_table_source(rules, rule_function_names))
  builder.to_string()
}

///|
fn emit_rules_table_source(
  rules : Array[RuleSpec],
  rule_function_names : Array[String],
) -> String {
  let builder = StringBuilder::new()
  let entries : Array[String] = []
  for rule_index in 0..<rules.length() {
    entries.push(
      "  \{emit_string_literal(rules[rule_index].rule_id)}: \{rule_function_names[rule_index]}",
    )
  }
  builder.write_string("///|\n")
  builder.write_string(
    "pub let moongrep_rules_table : Map[String, (String, Json, Array[MatchHit]) -> Bool raise] = {\n",
  )
  if !entries.is_empty() {
    builder.write_string(entries.join(",\n"))
    builder.write_string("\n")
  }
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn emit_rule_arm(
  rule : RuleSpec,
  pattern_index : Int,
  pattern : RulePatternSpec,
) -> String raise {
  let ast = @greptools.dump_expr_json_repr(pattern.shape)
  let ctx = { declared_metavars: emit_pattern_metavars(pattern), bindings: [] }
  let pattern_source = emit_pattern_source(ast, ctx, root=true)
  ensure_all_metavars_bound(
    rule.rule_id,
    pattern_index,
    emit_pattern_metavars(pattern),
    ctx,
  )
  let builder = StringBuilder::new()
  builder.write_string(
    "      // rule: \{rule.rule_id} pattern \{pattern_index}\n",
  )
  builder.write_string("      \{pattern_source} => {\n")
  let push_source = emit_push_source(rule, pattern_index, ctx)
  emit_name_only_guard_function_source(builder, pattern, ctx)
  emit_rule_arm_body(builder, pattern, ctx, push_source)
  builder.write_string("        true\n")
  builder.write_string("      }\n")
  builder.to_string()
}

///|
fn emit_rule_matcher_source(
  rule_function_name : String,
  rule : RuleSpec,
) -> String raise {
  let builder = StringBuilder::new()
  builder.write_string("///|\n")
  builder.write_string("// bundled rule: \{rule.rule_id}\n")
  builder.write_string("#warnings(\"-unused_error_type\")\n")
  builder.write_string(
    "fn \{rule_function_name}(file : String, ast : Json, hits : Array[MatchHit]) -> Bool raise {\n",
  )
  builder.write_string("  match ast {\n")
  for pattern_index in 0..<rule.patterns.length() {
    let pattern = rule.patterns[pattern_index]
    let arm = emit_rule_arm(rule, pattern_index, pattern)
    builder.write_string(arm)
  }
  builder.write_string("    _ => true\n")
  builder.write_string("  }\n")
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn emit_rule_matcher_function_names(
  rules : Array[RuleSpec],
) -> Array[String] raise {
  let rule_function_names : Array[String] = []
  let owner_rule_ids : Array[String] = []
  for rule in rules {
    let rule_function_name = emit_rule_matcher_function_name(rule.rule_id)
    for index in 0..<rule_function_names.length() {
      if rule_function_names[index] == rule_function_name {
        raise InvalidRule(
          path=rule.rule_id,
          info="rule matcher function name conflict: \{owner_rule_ids[index]} and \{rule.rule_id} both map to \{rule_function_name}",
        )
      }
    }
    rule_function_names.push(rule_function_name)
    owner_rule_ids.push(rule.rule_id)
  }
  rule_function_names
}

///|
fn emit_rule_matcher_function_name(rule_id : String) -> String {
  rule_id.replace_all(old="/", new="_").replace_all(old="-", new="_")
}

///|
fn ensure_all_metavars_bound(
  rule_id : String,
  pattern_index : Int,
  metavars : Array[String],
  ctx : PatternEmitContext,
) -> Unit raise {
  for meta_name in metavars {
    if find_binding_record(ctx, meta_name) is None {
      raise InvalidRule(
        path=rule_id,
        info="pattern[\{pattern_index}] declares unused metavar \{meta_name}",
      )
    }
  }
}

///|
fn emit_push_source(
  rule : RuleSpec,
  pattern_index : Int,
  ctx : PatternEmitContext,
) -> String {
  ignore(ctx)
  "hits.push(MatchHit::{ file, rule_id: \{emit_string_literal(rule.rule_id)}, package_name: \{emit_string_literal(rule.package_name)}, description: \{emit_string_literal(rule.description)}, pattern_index: \{pattern_index}, loc })"
}

///|
fn emit_duplicate_condition(
  pattern : RulePatternSpec,
  ctx : PatternEmitContext,
) -> String {
  let conditions : Array[String] = []
  for binding in ctx.bindings {
    if binding.bind_names.length() >= 2 {
      let first = if pattern.nameonly_metavars.contains(binding.meta_name) {
        emit_name_only_value_name(binding.meta_name, 1)
      } else {
        binding.bind_names[0]
      }
      for index in 1..<binding.bind_names.length() {
        let other = if pattern.nameonly_metavars.contains(binding.meta_name) {
          emit_name_only_value_name(binding.meta_name, index + 1)
        } else {
          binding.bind_names[index]
        }
        conditions.push("\{first} == \{other}")
      }
    }
  }
  conditions.join(" && ")
}

///|
fn emit_guarded_push_source(
  builder : StringBuilder,
  duplicate_condition : String,
  guard_source : String?,
  push_source : String,
  indent : String,
) -> Unit {
  match (duplicate_condition, guard_source) {
    ("", None) => builder.write_string("\{indent}\{push_source}\n")
    ("", Some(guard_source)) => {
      builder.write_string("\{indent}if \{guard_source} {\n")
      builder.write_string("\{indent}  \{push_source}\n")
      builder.write_string("\{indent}}\n")
    }
    (_, None) => {
      builder.write_string("\{indent}if \{duplicate_condition} {\n")
      builder.write_string("\{indent}  \{push_source}\n")
      builder.write_string("\{indent}}\n")
    }
    (_, Some(guard_source)) => {
      builder.write_string("\{indent}if \{duplicate_condition} {\n")
      builder.write_string("\{indent}  if \{guard_source} {\n")
      builder.write_string("\{indent}    \{push_source}\n")
      builder.write_string("\{indent}  }\n")
      builder.write_string("\{indent}}\n")
    }
  }
}

///|
fn emit_rule_arm_body(
  builder : StringBuilder,
  pattern : RulePatternSpec,
  ctx : PatternEmitContext,
  push_source : String,
) -> Unit {
  let duplicate_condition = emit_duplicate_condition(pattern, ctx)
  let guard_source = emit_guard_source(pattern, ctx)
  let name_only_bindings = collect_name_only_bindings(pattern, ctx)
  if name_only_bindings.is_empty() {
    emit_guarded_push_source(
      builder, duplicate_condition, guard_source, push_source, "        ",
    )
    return
  }
  for binding in name_only_bindings {
    builder.write_string(
      "        let \{emit_name_only_option_name(binding.meta_name, binding.occurrence)} = @greptools.normalize_metavar_name(\{binding.bind_name})\n",
    )
  }
  builder.write_string(
    "        match \{emit_name_only_match_expr(name_only_bindings)} {\n",
  )
  builder.write_string(
    "          \{emit_name_only_match_pattern(name_only_bindings)} => {\n",
  )
  emit_guarded_push_source(
    builder, duplicate_condition, guard_source, push_source, "            ",
  )
  builder.write_string("          }\n")
  builder.write_string("          _ => ()\n")
  builder.write_string("        }\n")
}

///|
fn collect_name_only_bindings(
  pattern : RulePatternSpec,
  ctx : PatternEmitContext,
) -> Array[NameOnlyBinding] {
  let name_only_bindings : Array[NameOnlyBinding] = []
  for binding in ctx.bindings {
    if pattern.nameonly_metavars.contains(binding.meta_name) {
      for index in 0..<binding.bind_names.length() {
        name_only_bindings.push({
          meta_name: binding.meta_name,
          occurrence: index + 1,
          bind_name: binding.bind_names[index],
        })
      }
    }
  }
  name_only_bindings
}

///|
fn emit_name_only_match_expr(bindings : Array[NameOnlyBinding]) -> String {
  if bindings.length() == 1 {
    emit_name_only_option_name(bindings[0].meta_name, bindings[0].occurrence)
  } else {
    let entries : Array[String] = []
    for binding in bindings {
      entries.push(
        emit_name_only_option_name(binding.meta_name, binding.occurrence),
      )
    }
    let joined = entries.join(", ")
    "(\{joined})"
  }
}

///|
fn emit_name_only_match_pattern(bindings : Array[NameOnlyBinding]) -> String {
  if bindings.length() == 1 {
    "Some(\{emit_name_only_value_name(bindings[0].meta_name, bindings[0].occurrence)})"
  } else {
    let entries : Array[String] = []
    for binding in bindings {
      entries.push(
        "Some(\{emit_name_only_value_name(binding.meta_name, binding.occurrence)})",
      )
    }
    let joined = entries.join(", ")
    "(\{joined})"
  }
}

///|
fn emit_guard_source(
  pattern : RulePatternSpec,
  ctx : PatternEmitContext,
) -> String? {
  match pattern.pattern_guard {
    None => None
    Some(guard_source) =>
      if pattern.nameonly_metavars.is_empty() {
        Some(guard_source)
      } else {
        let args : Array[String] = []
        for meta_name in emit_pattern_metavars(pattern) {
          if pattern.nameonly_metavars.contains(meta_name) {
            args.push(emit_name_only_value_name(meta_name, 1))
          } else {
            let binding = find_binding_record(ctx, meta_name).unwrap()
            args.push(binding.bind_names[0])
          }
        }
        let joined_args = args.join(", ")
        Some("\{emit_guard_function_name()}(\{joined_args})")
      }
  }
}

///|
fn emit_name_only_guard_function_source(
  builder : StringBuilder,
  pattern : RulePatternSpec,
  ctx : PatternEmitContext,
) -> Unit {
  ignore(ctx)
  guard pattern.pattern_guard is Some(guard_source) else { return }
  if pattern.nameonly_metavars.is_empty() {
    return
  }
  let params : Array[String] = []
  for meta_name in emit_pattern_metavars(pattern) {
    let param_type = if pattern.nameonly_metavars.contains(meta_name) {
      "String"
    } else {
      "Json"
    }
    params.push("\{meta_name} : \{param_type}")
  }
  let joined_params = params.join(", ")
  builder.write_string(
    "        fn \{emit_guard_function_name()}(\{joined_params}) -> Bool raise {\n",
  )
  for meta_name in emit_pattern_metavars(pattern) {
    builder.write_string("          ignore(\{meta_name})\n")
  }
  builder.write_string("          \{guard_source}\n")
  builder.write_string("        }\n")
}
