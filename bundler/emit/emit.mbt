///|
priv struct IdentifierBinding {
  meta_name : String
  occurrence : Int
  bind_name : String
}

///|
priv struct StructuralEmitRule {
  rule : @spec.RuleSpec
  patterns : Array[@spec.RulePatternSpec]
}

///|
fn emit_pattern_source(
  node : Json,
  ctx : PatternEmitContext,
  root? : Bool = false,
) -> String raise {
  match recognize_metavar(node, ctx) {
    Some(binding_name) => binding_name
    None =>
      match emit_ast_node_source(node, ctx, root~) {
        Some(source) => source
        None =>
          match node {
            Object(map) => {
              let keys : Array[String] = []
              for entry in map.iter() {
                keys.push(entry.0)
              }
              keys.sort()
              let fields : Array[String] = []
              for key in keys {
                let value = map.get(key).unwrap()
                let field_source = emit_pattern_source(value, ctx)
                fields.push("\{emit_string_literal(key)}: \{field_source}")
              }
              if fields.is_empty() {
                "{ .. }"
              } else {
                let joined_fields = fields.join(", ")
                "{ \{joined_fields}, .. }"
              }
            }
            Array(items) =>
              if items.is_empty() {
                "[]"
              } else {
                let item_sources : Array[String] = []
                for item in items {
                  item_sources.push(emit_pattern_source(item, ctx))
                }
                let joined_items = item_sources.join(", ")
                "[\{joined_items}]"
              }
            String(value) => emit_string_literal(value)
            Number(_, ..) | True | False => node.stringify()
            Null => "Null"
          }
      }
  }
}

///|
fn emit_ast_node_source(
  node : Json,
  ctx : PatternEmitContext,
  root? : Bool = false,
) -> String? raise {
  match node {
    Object(map) =>
      if map.length() == 3 {
        match (map.get("kind"), map.get("loc"), map.get("children")) {
          (Some(kind), Some(_), Some(children)) => {
            let kind_source = emit_pattern_source(kind, ctx)
            let children_source = emit_pattern_source(children, ctx)
            if root {
              Some(
                "{ \"kind\": \{kind_source}, \"loc\": loc, \"children\": \{children_source}, .. }",
              )
            } else {
              Some(
                "{ \"kind\": \{kind_source}, \"children\": \{children_source}, .. }",
              )
            }
          }
          _ => None
        }
      } else {
        None
      }
    _ => None
  }
}

///|
fn record_binding(ctx : PatternEmitContext, meta_name : String) -> String {
  for index in 0..<ctx.bindings.length() {
    if ctx.bindings[index].meta_name == meta_name {
      let bind_names = ctx.bindings[index].bind_names
      let bind_name = emit_binding_name(meta_name, bind_names.length() + 1)
      bind_names.push(bind_name)
      return bind_name
    }
  }
  let bind_name = emit_binding_name(meta_name, 1)
  ctx.bindings.push({ meta_name, bind_names: [bind_name] })
  bind_name
}

///|
fn emit_binding_name(meta_name : String, occurrence : Int) -> String {
  if occurrence == 1 {
    meta_name
  } else {
    "\{sanitize_identifier(meta_name)}_\{occurrence}"
  }
}

///|
fn find_binding_record(
  ctx : PatternEmitContext,
  meta_name : String,
) -> BindingRecord? {
  for binding in ctx.bindings {
    if binding.meta_name == meta_name {
      return Some(binding)
    }
  }
  None
}

///|
fn sanitize_identifier(name : String) -> String {
  let builder = StringBuilder::new(size_hint=name.length() + 5)
  builder.write_string("meta_")
  for index in 0..<name.length() {
    let ch = name.code_unit_at(index).unsafe_to_char()
    if ch == '_' ||
      ch.is_ascii_digit() ||
      ch is ('a'..='z') ||
      ch is ('A'..='Z') {
      builder.write_char(ch)
    } else {
      builder.write_char('_')
    }
  }
  builder.to_string()
}

///|
fn emit_generated_local_name(
  stem : String,
  meta_name : String,
  occurrence : Int,
) -> String {
  "__moongrep_\{stem}_\{sanitize_identifier(meta_name)}_\{occurrence}"
}

///|
fn emit_identifier_value_name(meta_name : String, occurrence : Int) -> String {
  emit_generated_local_name("identifier_name", meta_name, occurrence)
}

///|
fn emit_guard_function_name(pattern_index : Int) -> String {
  "__moongrep_guard_\{pattern_index}"
}

///|
fn emit_string_literal(value : String) -> String {
  Json::string(value).stringify()
}

///|
pub fn emit_bundle_source(rules : Array[@spec.RuleSpec]) -> String raise {
  let builder = StringBuilder::new()
  builder.write_string("// Generated by `moon run bundler`. DO NOT EDIT.\n")
  builder.write_string("\n")
  builder.write_string(emit_matcher_source(rules))
  builder.write_string("\n")
  builder.write_string(emit_taint_bundle_source(rules))
  builder.to_string()
}

///|
fn emit_matcher_source(rules : Array[@spec.RuleSpec]) -> String raise {
  let builder = StringBuilder::new()
  let structural_rules = collect_structural_rules(rules)
  let rule_function_names = emit_rule_matcher_function_names(structural_rules)
  for rule_index in 0..<structural_rules.length() {
    builder.write_string(
      emit_rule_matcher_source(
        rule_function_names[rule_index],
        structural_rules[rule_index].rule,
        structural_rules[rule_index].patterns,
      ),
    )
    builder.write_string("\n")
  }
  builder.write_string(
    emit_rules_table_source(structural_rules, rule_function_names),
  )
  builder.to_string()
}

///|
fn collect_structural_rules(
  rules : Array[@spec.RuleSpec],
) -> Array[StructuralEmitRule] {
  let structural_rules : Array[StructuralEmitRule] = []
  for rule in rules {
    match rule.definition {
      @spec.RuleDefinitionSpec::Structural(patterns) =>
        structural_rules.push({ rule, patterns })
      @spec.RuleDefinitionSpec::Taint(_) => ()
    }
  }
  structural_rules
}

///|
fn emit_rules_table_source(
  rules : Array[StructuralEmitRule],
  rule_function_names : Array[String],
) -> String {
  let builder = StringBuilder::new()
  let entries : Array[String] = []
  for rule_index in 0..<rules.length() {
    entries.push(
      "  \{emit_string_literal(rules[rule_index].rule.rule_id)}: \{rule_function_names[rule_index]}",
    )
  }
  builder.write_string("///|\n")
  builder.write_string(
    "pub let moongrep_rules_table : Map[String, (String, Json, Array[MatchHit]) -> Bool raise] = {\n",
  )
  if !entries.is_empty() {
    builder.write_string(entries.join(",\n"))
    builder.write_string("\n")
  }
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn emit_rule_arm(
  rule : @spec.RuleSpec,
  pattern_index : Int,
  pattern : @spec.RulePatternSpec,
) -> String raise {
  let ast = @greptools.dump_expr_json_repr(pattern.shape)
  let ctx = {
    declared_metavars: pattern.declared_metavars(),
    special_wildcards: [],
    bindings: [],
  }
  let pattern_source = emit_pattern_source(ast, ctx, root=true)
  ensure_all_metavars_bound(
    rule.rule_id,
    pattern_index,
    pattern.declared_metavars(),
    ctx,
  )
  let builder = StringBuilder::new()
  builder.write_string(
    "      // rule: \{rule.rule_id} pattern \{pattern_index}\n",
  )
  let guard_source = emit_rule_arm_guard_source(pattern, pattern_index, ctx)
  match guard_source {
    Some(guard_source) =>
      builder.write_string("      \{pattern_source} if \{guard_source} => {\n")
    None => builder.write_string("      \{pattern_source} => {\n")
  }
  let push_source = emit_push_source(rule, pattern_index, ctx)
  builder.write_string("        \{push_source}\n")
  builder.write_string("        true\n")
  builder.write_string("      }\n")
  builder.to_string()
}

///|
fn emit_rule_matcher_source(
  rule_function_name : String,
  rule : @spec.RuleSpec,
  patterns : Array[@spec.RulePatternSpec],
) -> String raise {
  let builder = StringBuilder::new()
  builder.write_string("///|\n")
  builder.write_string("// bundled rule: \{rule.rule_id}\n")
  builder.write_string("#warnings(\"-unused_error_type\")\n")
  builder.write_string(
    "fn \{rule_function_name}(file : String, ast : Json, hits : Array[MatchHit]) -> Bool raise {\n",
  )
  builder.write_string(emit_rule_guard_function_sources(patterns))
  builder.write_string("  match ast {\n")
  for pattern_index in 0..<patterns.length() {
    let pattern = patterns[pattern_index]
    let arm = emit_rule_arm(rule, pattern_index, pattern)
    builder.write_string(arm)
  }
  builder.write_string("    _ => true\n")
  builder.write_string("  }\n")
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn emit_rule_matcher_function_names(
  rules : Array[StructuralEmitRule],
) -> Array[String] raise {
  let rule_function_names : Array[String] = []
  let owner_rule_ids : Array[String] = []
  for rule in rules {
    let rule_function_name = emit_rule_matcher_function_name(rule.rule.rule_id)
    for index in 0..<rule_function_names.length() {
      if rule_function_names[index] == rule_function_name {
        raise @spec.invalid_rule(
          path=rule.rule.rule_id,
          info="rule matcher function name conflict: \{owner_rule_ids[index]} and \{rule.rule.rule_id} both map to \{rule_function_name}",
        )
      }
    }
    rule_function_names.push(rule_function_name)
    owner_rule_ids.push(rule.rule.rule_id)
  }
  rule_function_names
}

///|
fn emit_rule_matcher_function_name(rule_id : String) -> String {
  rule_id.replace_all(old="/", new="_").replace_all(old="-", new="_")
}

///|
fn ensure_all_metavars_bound(
  rule_id : String,
  pattern_index : Int,
  metavars : Array[String],
  ctx : PatternEmitContext,
) -> Unit raise {
  for meta_name in metavars {
    if find_binding_record(ctx, meta_name) is None {
      raise @spec.invalid_rule(
        path=rule_id,
        info="pattern[\{pattern_index}] declares unused metavar \{meta_name}",
      )
    }
  }
}

///|
fn emit_push_source(
  rule : @spec.RuleSpec,
  pattern_index : Int,
  ctx : PatternEmitContext,
) -> String {
  ignore(ctx)
  "hits.push(MatchHit::{ file, rule_id: \{emit_string_literal(rule.rule_id)}, package_name: \{emit_string_literal(rule.package_name)}, description: \{emit_string_literal(rule.description)}, pattern_index: \{pattern_index}, loc })"
}

///|
fn emit_duplicate_condition(
  pattern : @spec.RulePatternSpec,
  ctx : PatternEmitContext,
) -> String {
  let conditions : Array[String] = []
  for binding in ctx.bindings {
    if binding.bind_names.length() >= 2 {
      let is_identifier = pattern.identifier_metavars.contains(
        binding.meta_name,
      )
      for index in 1..<binding.bind_names.length() {
        if is_identifier {
          let first = emit_identifier_value_name(binding.meta_name, 1)
          let other = emit_identifier_value_name(binding.meta_name, index + 1)
          conditions.push("\{first} == \{other}")
        } else {
          conditions.push(
            "@greptools.ast_json_repr_equal(\{binding.bind_names[0]}, \{binding.bind_names[index]})",
          )
        }
      }
    }
  }
  conditions.join(" && ")
}

///|
fn emit_rule_arm_guard_source(
  pattern : @spec.RulePatternSpec,
  pattern_index : Int,
  ctx : PatternEmitContext,
) -> String? {
  let clauses : Array[String] = []
  for condition in emit_identifier_normalization_conditions(pattern, ctx) {
    clauses.push(condition)
  }
  let duplicate_condition = emit_duplicate_condition(pattern, ctx)
  if duplicate_condition != "" {
    clauses.push(duplicate_condition)
  }
  match emit_guard_source(pattern, pattern_index, ctx) {
    Some(guard_source) => clauses.push(guard_source)
    None => ()
  }
  if clauses.is_empty() {
    None
  } else {
    Some(clauses.join(" && "))
  }
}

///|
fn emit_identifier_normalization_conditions(
  pattern : @spec.RulePatternSpec,
  ctx : PatternEmitContext,
) -> Array[String] {
  let conditions : Array[String] = []
  for binding in collect_identifier_bindings(pattern, ctx) {
    let normalized_name = emit_identifier_value_name(
      binding.meta_name,
      binding.occurrence,
    )
    conditions.push(
      "@greptools.normalize_identifier_name(\{binding.bind_name}) is Some(\{normalized_name})",
    )
  }
  conditions
}

///|
fn emit_rule_guard_function_sources(
  patterns : Array[@spec.RulePatternSpec],
) -> String {
  let builder = StringBuilder::new()
  let mut has_helper = false
  for pattern_index in 0..<patterns.length() {
    let helper_source = emit_identifier_guard_function_source(
      pattern_index,
      patterns[pattern_index],
    )
    if helper_source != "" {
      builder.write_string(helper_source)
      builder.write_string("\n")
      has_helper = true
    }
  }
  if has_helper {
    builder.write_string("\n")
  }
  builder.to_string()
}

///|
fn collect_identifier_bindings(
  pattern : @spec.RulePatternSpec,
  ctx : PatternEmitContext,
) -> Array[IdentifierBinding] {
  let identifier_bindings : Array[IdentifierBinding] = []
  for binding in ctx.bindings {
    if pattern.identifier_metavars.contains(binding.meta_name) {
      for index in 0..<binding.bind_names.length() {
        identifier_bindings.push({
          meta_name: binding.meta_name,
          occurrence: index + 1,
          bind_name: binding.bind_names[index],
        })
      }
    }
  }
  identifier_bindings
}

///|
fn emit_guard_source(
  pattern : @spec.RulePatternSpec,
  pattern_index : Int,
  ctx : PatternEmitContext,
) -> String? {
  match pattern.pattern_guard {
    None => None
    Some(guard_source) =>
      if pattern.identifier_metavars.is_empty() {
        Some("(\{guard_source})")
      } else {
        let args : Array[String] = []
        for meta_name in pattern.declared_metavars() {
          if pattern.identifier_metavars.contains(meta_name) {
            args.push(emit_identifier_value_name(meta_name, 1))
          } else {
            let binding = find_binding_record(ctx, meta_name).unwrap()
            args.push(binding.bind_names[0])
          }
        }
        let joined_args = args.join(", ")
        Some("\{emit_guard_function_name(pattern_index)}(\{joined_args})")
      }
  }
}

///|
fn emit_identifier_guard_function_source(
  pattern_index : Int,
  pattern : @spec.RulePatternSpec,
) -> String {
  guard pattern.pattern_guard is Some(guard_source) else { return "" }
  if pattern.identifier_metavars.is_empty() {
    return ""
  }
  let builder = StringBuilder::new()
  let params : Array[String] = []
  for meta_name in pattern.declared_metavars() {
    let param_type = if pattern.identifier_metavars.contains(meta_name) {
      "String"
    } else {
      "Json"
    }
    params.push("\{meta_name} : \{param_type}")
  }
  let joined_params = params.join(", ")
  builder.write_string(
    "  fn \{emit_guard_function_name(pattern_index)}(\{joined_params}) -> Bool raise {\n",
  )
  for meta_name in pattern.declared_metavars() {
    builder.write_string("    ignore(\{meta_name})\n")
  }
  builder.write_string("    \{guard_source}\n")
  builder.write_string("  }\n")
  builder.to_string()
}
